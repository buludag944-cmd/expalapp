# Copy to backend/.env and fill in values. Restart the server after changes.
#   cp .env.example .env

# App — keep backend on 3001; run frontend (CRA) on 3000
PORT=3001
CLIENT_URL=http://localhost:3000
# Production (email verify/reset links — must match Capacitor SPA host):
# CLIENT_URL=https://expalapp.netlify.app
JWT_SECRET=change-me-in-production

# SMTP — required for verification emails (no Ethereal fallback)
# Gmail: enable 2-Step Verification, create App Password, use it as SMTP_PASS
# Brevo/Mailgun/Mailersend: use SMTP credentials from the provider dashboard
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM="EXPal" <your@gmail.com>

# Railway / production (optional — set in Railway Variables instead of committing .env)
# DATABASE_PATH=/data/expal.db